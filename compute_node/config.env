# === LLM Refinery — GPU Pod Config ===
# Change ONLY this IP when your local Tailscale IP changes.
# All service URLs below are derived from it.
CONTROL_PLANE_IP=100.89.94.1

# CUDA 13 libs for PyTorch/bitsandbytes
LD_LIBRARY_PATH=/usr/local/lib/python3.11/dist-packages/nvidia/cu13/lib:${LD_LIBRARY_PATH:-}

# Service URLs — point to localhost because pod-side socat tunnels
# forward through Tailscale to the control plane.
REDIS_URL=redis://127.0.0.1:16379/0
MLFLOW_TRACKING_URI=http://127.0.0.1:15000
MINIO_ENDPOINT=127.0.0.1:19000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=datasets

# Persistent cache (survives pod restarts)
HF_HOME=/workspace/hf_cache
TRANSFORMERS_CACHE=/workspace/hf_cache
MODEL_OUTPUT_DIR=/workspace/models
